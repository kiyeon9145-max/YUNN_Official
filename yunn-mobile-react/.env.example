# YUNN React public runtime config
# Copy this file to .env.local for local development.
# Set the same keys in Vercel Project Settings > Environment Variables.

# Required: Google Tag Manager container used by the React app.
NEXT_PUBLIC_YUNN_GTM_ID=

# Required: Google Apps Script Web App URL that receives non-PII survey completion rows.
NEXT_PUBLIC_YUNN_SHEET_ENDPOINT=

# Optional: App version attached to analytics payloads.
NEXT_PUBLIC_YUNN_APP_VERSION=

# Optional: Remote analytics collector endpoint; leave empty when using only GTM/dataLayer/localStorage.
NEXT_PUBLIC_YUNN_ANALYTICS_ENDPOINT=

# Optional: GA4 measurement ID if the app later sends GA events directly instead of only via GTM.
NEXT_PUBLIC_YUNN_GA_MEASUREMENT_ID=

# Optional: Google Form URL for future feedback/contact collection.
NEXT_PUBLIC_YUNN_FEEDBACK_FORM_URL=
